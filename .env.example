# ============================================================
# 环境变量配置模板，复制为 .env 后填入实际值
# 生产环境必须修改全部变量，不得使用默认值
# ============================================================

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_strong_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT（至少 256 bit 随机字符串，可用 openssl rand -base64 32 生成）
JWT_SECRET=your_256bit_random_secret_here

# 网关内部通信密钥
GATEWAY_INTERNAL_SECRET=your_gateway_secret_here

# CORS 允许的前端域名（多个用逗号分隔）
CORS_ALLOWED_ORIGINS=http://localhost:3000

# 微信开放平台（PC 扫码登录）
WEIXIN_APP_ID=your_weixin_app_id
WEIXIN_APP_SECRET=your_weixin_app_secret
WEIXIN_REDIRECT_URI=http://your-domain.com/weixin/callback
